local function animateTabButton(button, selected)
	local goalBg = selected and Color3.fromRGB(16, 20, 30) or Color3.fromRGB(8, 8, 18)
	local goalText = selected and Color3.fromRGB(190, 255, 120) or Color3.fromRGB(200, 200, 200)

	TweenService:Create(button, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundColor3 = goalBg,
		TextColor3 = goalText
	}):Play()
end

local function switchTab(tabName)
	if tabAnimating or activeTab == tabName then
		return
	end

	tabAnimating = true

	local oldPage = activeTab == "Visuals" and visualsPage or settingsPage
	local newPage = tabName == "Visuals" and visualsPage or settingsPage
	local moveLeft = tabName == "Settings"

	newPage.Visible = true
	newPage.Position = moveLeft and UDim2.new(1, 0, 0, 0) or UDim2.new(-1, 0, 0, 0)

	local tweenOut = TweenService:Create(
		oldPage,
		TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{Position = moveLeft and UDim2.new(-1, 0, 0, 0) or UDim2.new(1, 0, 0, 0)}
	)

	local tweenIn = TweenService:Create(
		newPage,
		TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{Position = UDim2.new(0, 0, 0, 0)}
	)

	animateTabButton(tabVisuals, tabName == "Visuals")
	animateTabButton(tabSettings, tabName == "Settings")

	tweenOut:Play()
	tweenIn:Play()

	tweenIn.Completed:Connect(function()
		oldPage.Visible = false
		oldPage.Position = UDim2.new(0, 0, 0, 0)
		activeTab = tabName
		tabAnimating = false
	end)
end

local function stopZombieLock()
	zombieLockEnabled = false
	currentZombieTarget = nil
	lockCircle.Visible = false

	if zombieLockConnection then
		zombieLockConnection:Disconnect()
		zombieLockConnection = nil
	end

	updateDynamicTexts()
	updateStatusText()
end

local function startZombieLock()
	if zombieLockConnection then
		zombieLockConnection:Disconnect()
		zombieLockConnection = nil
	end

	zombieLockEnabled = true
	currentZombieTarget = nil
	lockCircle.Visible = true
	lastTargetScan = 0

	zombieLockConnection = RunService.RenderStepped:Connect(function()
		if not zombieLockEnabled then
			return
		end

		local myCharacter = LocalPlayer.Character
		local myHumanoid = myCharacter and myCharacter:FindFirstChildOfClass("Humanoid")
		local myRoot = myCharacter and myCharacter:FindFirstChild("HumanoidRootPart")

		if not myCharacter or not myHumanoid or myHumanoid.Health <= 0 or not myRoot then
			currentZombieTarget = nil
			updateDynamicTexts()
			updateStatusText()
			return
		end

		updateCirclePosition()

		local now = tick()
		if now - lastTargetScan >= TARGET_SCAN_INTERVAL then
			lastTargetScan = now

			local bestTarget = getBestTargetInCircle()
			if bestTarget ~= currentZombieTarget then
				currentZombieTarget = bestTarget
				updateDynamicTexts()
				updateStatusText()
			end
		end

		if currentZombieTarget then
			if not currentZombieTarget.Parent
				or not isValidZombieTarget(currentZombieTarget)
				or not isTargetVisible(currentZombieTarget)
				or not isTargetInsideLockCircle(currentZombieTarget) then
				currentZombieTarget = nil
				updateDynamicTexts()
				updateStatusText()
				return
			end

			local head = currentZombieTarget:FindFirstChild("Head")
			if head then
				local camPos = Camera.CFrame.Position
				Camera.CFrame = CFrame.new(camPos, head.Position)
			else
				currentZombieTarget = nil
				updateDynamicTexts()
				updateStatusText()
			end
		end
	end)

	updateCirclePosition()
	updateDynamicTexts()
	updateStatusText()
end

