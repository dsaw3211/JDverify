UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then
		return
	end

	if input.UserInputType ~= Enum.UserInputType.Keyboard then
		return
	end

	if waitingForKeybind then
		setKeybind(waitingForKeybind, input.KeyCode)
		waitingForKeybind = nil
		updateDynamicTexts()
		updateStatusText()
		return
	end

	if input.KeyCode == Enum.KeyCode.W then
		flyControls.Forward = true
	elseif input.KeyCode == Enum.KeyCode.S then
		flyControls.Backward = true
	elseif input.KeyCode == Enum.KeyCode.A then
		flyControls.Left = true
	elseif input.KeyCode == Enum.KeyCode.D then
		flyControls.Right = true
	elseif input.KeyCode == Enum.KeyCode.Space then
		flyControls.Up = true
	elseif input.KeyCode == Enum.KeyCode.LeftControl then
		flyControls.Down = true
	end

	if input.KeyCode == Keybinds.ToggleUI and unlocked then
		uiOpen = not uiOpen
		main.Visible = uiOpen
	end

	if input.KeyCode == Keybinds.DestroyUI then
		destroyUI()
	end

	if input.KeyCode == Keybinds.FreeMouse then
		UserInputService.MouseBehavior = Enum.MouseBehavior.Default
		UserInputService.MouseIconEnabled = true
	end

	if input.KeyCode == Keybinds.ZombieLock and unlocked then
		toggleZombieLock()
	end

	if input.KeyCode == Keybinds.Highlight and unlocked then
		toggleHighlight()
	end

	if input.KeyCode == Keybinds.NameTags and unlocked then
		toggleNameTags()
	end

	if input.KeyCode == Keybinds.TeamCheck and unlocked then
		toggleTeamCheck()
	end

	if input.KeyCode == Keybinds.Fly and unlocked then
		toggleFly()
	end
end)

local function hookPlayer(player)
	player.CharacterAdded:Connect(function(character)
		task.wait(1)
		if unlocked then
			removeVisuals(character)
			rebuildModelCache()
			updateAllPlayers()
			updateStatusText()
		end
	end)

	player.CharacterRemoving:Connect(function(character)
		removeVisuals(character)
		if currentZombieTarget == character then
			currentZombieTarget = nil
			updateStatusText()
		end
	end)

	player:GetPropertyChangedSignal("Team"):Connect(function()
		if unlocked then
			currentZombieTarget = nil
			updateAllPlayers()
			updateStatusText()
		end
	end)
end

local function hookLocalCharacter(character)
	currentZombieTarget = nil
	stopFlyController()

	task.defer(function()
		local humanoid = character:FindFirstChildOfClass("Humanoid")
		if humanoid then
			humanoid.Died:Connect(function()
				currentZombieTarget = nil
				stopFlyController()

				if zombieLockEnabled then
					stopZombieLock()
				end
			end)
		end
	end)

	task.spawn(function()
		task.wait(1)
		if unlocked then
			fullRefreshAfterRespawn()
			applyWalkSpeed()
		end
	end)
end

