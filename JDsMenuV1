applyVisualsFilter = function()
	local query = string.lower(visualsSearchBox.Text or "")
	local hasQuery = query ~= ""

	for _, row in ipairs(searchableRows) do
		local terms = row:GetAttribute("SearchTerms") or ""
		row.Visible = (not hasQuery) or string.find(terms, query, 1, true) ~= nil
	end

	for _, data in pairs(sectionRegistry) do
		local hasVisibleRow = false
		for _, child in ipairs(data.Content:GetChildren()) do
			if child:IsA("Frame") and child.Visible then
				hasVisibleRow = true
				break
			end
		end

		local sectionMatch = hasQuery and string.find(string.lower(data.Name), query, 1, true) ~= nil
		local sectionVisible = (not hasQuery) or hasVisibleRow or sectionMatch

		data.Frame.Visible = sectionVisible
		data.Content.Visible = sectionVisible and (not data.Collapsed)
	end

	visualsPage.CanvasPosition = Vector2.new(0, 0)
	visualsPage.CanvasSize = UDim2.new(0, 0, 0, visualsList.AbsoluteContentSize.Y + 20)
end

