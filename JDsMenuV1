Workspace.DescendantRemoving:Connect(function(desc)
	if desc:IsA("Model") then
		removeModelFromCache(desc)
		if currentZombieTarget == desc then
			currentZombieTarget = nil
		end
	elseif desc:IsA("Humanoid") then
		local model = getCharacterModelFromDescendant(desc)
		if model then
			removeModelFromCache(model)
			if currentZombieTarget == model then
				currentZombieTarget = nil
			end
		end
	end
end)

