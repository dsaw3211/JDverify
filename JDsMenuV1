local function getLocalTeamValue()
	if LocalPlayer.Team then
		return LocalPlayer.Team.Name
	end
	return nil
end

local function normalizeTeamValue(value)
	if value == nil then
		return nil
	end

	local valueType = typeof(value)

	if valueType == "Instance" then
		return value.Name
	end

	if valueType == "BrickColor" then
		return value.Name
	end

	if valueType == "Color3" then
		return tostring(value)
	end

	return tostring(value)
end

local function getModelTeam(model)
	if not model or not model:IsA("Model") then
		return nil
	end

	local player = Players:GetPlayerFromCharacter(model)
	if player and player.Team then
		return normalizeTeamValue(player.Team)
	end

	for _, attrName in ipairs({
		"Team",
		"team",
		"Faction",
		"faction",
		"Side",
		"side",
		"Allegiance",
		"allegiance",
	}) do
		local attrValue = model:GetAttribute(attrName)
		if attrValue ~= nil then
			return normalizeTeamValue(attrValue)
		end
	end

	for _, childName in ipairs({
		"Team",
		"team",
		"Faction",
		"faction",
		"Side",
		"side",
		"Allegiance",
		"allegiance",
	}) do
		local obj = model:FindFirstChild(childName)
		if obj then
			if obj:IsA("ObjectValue") then
				return normalizeTeamValue(obj.Value)
			elseif obj:IsA("StringValue") then
				return normalizeTeamValue(obj.Value)
			elseif obj:IsA("BrickColorValue") then
				return normalizeTeamValue(obj.Value)
			elseif obj:IsA("Color3Value") then
				return normalizeTeamValue(obj.Value)
			elseif obj:IsA("IntValue") or obj:IsA("NumberValue") then
				return tostring(obj.Value)
			end
		end
	end

	local humanoid = model:FindFirstChildOfClass("Humanoid")
	if humanoid then
		for _, attrName in ipairs({
			"Team",
			"team",
			"Faction",
			"faction",
			"Side",
			"side",
			"Allegiance",
			"allegiance",
		}) do
			local attrValue = humanoid:GetAttribute(attrName)
			if attrValue ~= nil then
				return normalizeTeamValue(attrValue)
			end
		end
	end

	return nil
end

local function modelIsEnemy(model)
	if not model or not model:IsA("Model") then
		return false
	end

	local myCharacter = LocalPlayer.Character
	if myCharacter and model == myCharacter then
		return false
	end

	if not teamCheckEnabled then
		return true
	end

	local myTeam = getLocalTeamValue()
	local targetTeam = getModelTeam(model)

	if myTeam and targetTeam and myTeam == targetTeam then
		return false
	end

	if myTeam and targetTeam then
		return myTeam ~= targetTeam
	end

	local player = Players:GetPlayerFromCharacter(model)
	if player then
		return false
	end

	return false
end

local function updateCirclePosition()
	local mousePos = getMouseScreenPosition()
	lockCircle.Position = UDim2.new(0, mousePos.X, 0, mousePos.Y)
end

local function getTargetScreenPosition(model)
	if not model then
		return nil, false
	end

	local head = model:FindFirstChild("Head")
	if not head then
		return nil, false
	end

	local screenPoint, onScreen = Camera:WorldToViewportPoint(head.Position)
	if not onScreen or screenPoint.Z <= 0 then
		return nil, false
	end

	return Vector2.new(screenPoint.X, screenPoint.Y), true
end

local function isTargetInsideLockCircle(model)
	local screenPos, onScreen = getTargetScreenPosition(model)
	if not onScreen or not screenPos then
		return false
	end

	local mousePos = getMouseScreenPosition()
	local dist = (screenPos - mousePos).Magnitude
	return dist <= LOCK_RADIUS
end

local function isTargetVisible(model)
	if not model then
		return false
	end

	local head = model:FindFirstChild("Head")
	if not head then
		return false
	end

	local origin = Camera.CFrame.Position
	local direction = head.Position - origin

	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = {
		LocalPlayer.Character,
		model,
		Camera
	}
	params.IgnoreWater = true

	local result = Workspace:Raycast(origin, direction, params)

	if not result then
		return true
	end

	return result.Instance and result.Instance:IsDescendantOf(model)
end

local function isValidZombieTarget(model)
	if not model or not model:IsA("Model") then
		return false
	end

	if model == LocalPlayer.Character then
		return false
	end

	local humanoid = model:FindFirstChildOfClass("Humanoid")
	local head = model:FindFirstChild("Head")
	local root = model:FindFirstChild("HumanoidRootPart")

	if not humanoid or humanoid.Health <= 0 then
		return false
	end

	if not head or not root then
		return false
	end

	if not modelIsEnemy(model) then
		return false
	end

	return true
end

local function getTargetWorldDistance(model)
	local myCharacter = LocalPlayer.Character
	if not myCharacter then
		return math.huge
	end

	local myRoot = myCharacter:FindFirstChild("HumanoidRootPart")
	local targetRoot = model and model:FindFirstChild("HumanoidRootPart")

	if not myRoot or not targetRoot then
		return math.huge
	end

	return (targetRoot.Position - myRoot.Position).Magnitude
end

local function getBestTargetInCircle()
	local bestTarget = nil
	local bestMouseDistance = math.huge
	local bestWorldDistance = math.huge
	local mousePos = getMouseScreenPosition()

	for model in pairs(modelCache) do
		if not model or not model.Parent then
			modelCache[model] = nil
		else
			if isValidZombieTarget(model) then
				local screenPos, onScreen = getTargetScreenPosition(model)
				if onScreen and screenPos and isTargetVisible(model) then
					local mouseDistance = (screenPos - mousePos).Magnitude
					if mouseDistance <= LOCK_RADIUS then
						local worldDistance = getTargetWorldDistance(model)

						if mouseDistance < bestMouseDistance
							or (math.abs(mouseDistance - bestMouseDistance) < 0.001 and worldDistance < bestWorldDistance) then
							bestMouseDistance = mouseDistance
							bestWorldDistance = worldDistance
							bestTarget = model
						end
					end
				end
			end
		end
	end

	return bestTarget
end

