local function keyCodeToText(keyCode)
	if not keyCode then
		return "NONE"
	end
	return keyCode.Name
end

local function applyZIndex(_, mapping)
	for _, pair in ipairs(mapping) do
		local obj = pair[1]
		local z = pair[2]
		if obj and obj:IsA("GuiObject") then
			obj.ZIndex = z
		end
	end
end

local function setDescendantZIndex(root, z)
	if root and root:IsA("GuiObject") then
		root.ZIndex = z
	end

	for _, desc in ipairs(root:GetDescendants()) do
		if desc:IsA("GuiObject") then
			desc.ZIndex = z
		end
	end
end

local function getMouseScreenPosition()
	local inset = GuiService:GetGuiInset()
	local mousePos = UserInputService:GetMouseLocation()
	return Vector2.new(mousePos.X - inset.X, mousePos.Y - inset.Y)
end

local function getCharacterModelFromDescendant(desc)
	local current = desc
	while current and current ~= Workspace do
		if current:IsA("Model") and current:FindFirstChildOfClass("Humanoid") then
			return current
		end
		current = current.Parent
	end
	return nil
end

local function addModelToCache(model)
	if model and model:IsA("Model") then
		modelCache[model] = true
	end
end

local function removeModelFromCache(model)
	if model then
		modelCache[model] = nil
	end
end

local function rebuildModelCache()
	table.clear(modelCache)

	for _, desc in ipairs(Workspace:GetDescendants()) do
		if desc:IsA("Humanoid") then
			local model = getCharacterModelFromDescendant(desc)
			if model then
				addModelToCache(model)
			end
		elseif desc:IsA("Model") and desc:FindFirstChildOfClass("Humanoid") then
			addModelToCache(desc)
		end
	end
end

local function getLocalHumanoid()
	local character = LocalPlayer.Character
	if not character then
		return nil
	end
	return character:FindFirstChildOfClass("Humanoid")
end

local function getLocalRootPart()
	local character = LocalPlayer.Character
	if not character then
		return nil
	end
	return character:FindFirstChild("HumanoidRootPart")
end

local function clampWalkSpeed(value)
	return math.clamp(math.floor(value + 0.5), MIN_SPEED, MAX_SPEED)
end

local function clampFlySpeed(value)
	return math.clamp(math.floor(value + 0.5), MIN_FLY_SPEED, MAX_FLY_SPEED)
end

local function applyWalkSpeed()
	local humanoid = getLocalHumanoid()
	if humanoid then
		humanoid.WalkSpeed = currentWalkSpeed
	end
end

local function stopSpeedEnforcement()
	if speedEnforceConnection then
		speedEnforceConnection:Disconnect()
		speedEnforceConnection = nil
	end
end

local function startSpeedEnforcement()
	stopSpeedEnforcement()

	speedEnforceConnection = RunService.RenderStepped:Connect(function()
		if not unlocked then
			return
		end

		local humanoid = getLocalHumanoid()
		if humanoid and humanoid.Health > 0 and humanoid.WalkSpeed ~= currentWalkSpeed then
			humanoid.WalkSpeed = currentWalkSpeed
		end
	end)
end

local function clearFlyMovement()
	for key in pairs(flyControls) do
		flyControls[key] = false
	end
end

local function destroyFlyObjects()
	if flyRenderConnection then
		flyRenderConnection:Disconnect()
		flyRenderConnection = nil
	end

	if flyBodyVelocity then
		flyBodyVelocity:Destroy()
		flyBodyVelocity = nil
	end

	local root = getLocalRootPart()
	if root then
		root.AssemblyLinearVelocity = Vector3.zero
	end

	flyCurrentVelocity = Vector3.zero
	clearFlyMovement()
end

local function getFlyMoveDirection()
	local forwardAxis = (flyControls.Forward and 1 or 0) - (flyControls.Backward and 1 or 0)
	local rightAxis = (flyControls.Right and 1 or 0) - (flyControls.Left and 1 or 0)
	local verticalAxis = (flyControls.Up and 1 or 0) - (flyControls.Down and 1 or 0)

	local lookVector = Camera.CFrame.LookVector
	local rightVector = Camera.CFrame.RightVector

	local flatLook = Vector3.new(lookVector.X, 0, lookVector.Z)
	local flatRight = Vector3.new(rightVector.X, 0, rightVector.Z)

	if flatLook.Magnitude > 0 then
		flatLook = flatLook.Unit
	end

	if flatRight.Magnitude > 0 then
		flatRight = flatRight.Unit
	end

	local moveDirection = (flatLook * forwardAxis) + (flatRight * rightAxis) + Vector3.new(0, verticalAxis, 0)

	if moveDirection.Magnitude > 1 then
		moveDirection = moveDirection.Unit
	end

	return moveDirection
end

local function startFlyController()
	destroyFlyObjects()

	local character = LocalPlayer.Character
	local humanoid = getLocalHumanoid()
	local root = getLocalRootPart()

	if not character or not humanoid or humanoid.Health <= 0 or not root then
		return
	end

	local existing = root:FindFirstChild("AdminFlyVelocity")
	if existing and existing:IsA("BodyVelocity") then
		flyBodyVelocity = existing
	else
		flyBodyVelocity = Instance.new("BodyVelocity")
		flyBodyVelocity.Name = "AdminFlyVelocity"
		flyBodyVelocity.MaxForce = FLY_FORCE
		flyBodyVelocity.P = 15000
		flyBodyVelocity.Velocity = Vector3.zero
		flyBodyVelocity.Parent = root
	end

	humanoid:ChangeState(Enum.HumanoidStateType.Freefall)
	flyCurrentVelocity = Vector3.zero

	flyRenderConnection = RunService.RenderStepped:Connect(function(deltaTime)
		if not flyEnabled then
			return
		end

		local currentCharacter = LocalPlayer.Character
		local currentHumanoid = getLocalHumanoid()
		local currentRoot = getLocalRootPart()

		if not currentCharacter or not currentHumanoid or currentHumanoid.Health <= 0 or not currentRoot then
			destroyFlyObjects()
			return
		end

		if not flyBodyVelocity or flyBodyVelocity.Parent ~= currentRoot then
			destroyFlyObjects()
			if flyEnabled then
				startFlyController()
			end
			return
		end

		local desiredDirection = getFlyMoveDirection()
		local desiredVelocity = desiredDirection * currentFlySpeed
		local lerpAlpha = math.clamp(deltaTime * FLY_SMOOTHNESS, 0, 1)

		flyCurrentVelocity = flyCurrentVelocity:Lerp(desiredVelocity, lerpAlpha)
		flyBodyVelocity.Velocity = flyCurrentVelocity
		currentHumanoid:ChangeState(Enum.HumanoidStateType.Freefall)
	end)
end

local function stopFlyController()
	destroyFlyObjects()

	local humanoid = getLocalHumanoid()
	if humanoid and humanoid.Health > 0 then
		humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
	end
end

local function setFlyEnabled(enabled)
	if flyEnabled == enabled then
		return
	end

	flyEnabled = enabled

	if flyEnabled then
		startFlyController()
	else
		stopFlyController()
	end

	if updateDynamicTexts then
		updateDynamicTexts()
	end
	if updateStatusText then
		updateStatusText()
	end
end

local function toggleFly()
	setFlyEnabled(not flyEnabled)
end

